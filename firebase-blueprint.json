{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email"]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "Information about a recorded meeting.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique meeting ID." },
        "userId": { "type": "string", "description": "ID of the user who recorded the meeting." },
        "title": { "type": "string", "description": "Title of the meeting." },
        "date": { "type": "string", "format": "date-time", "description": "When the meeting was recorded." },
        "duration": { "type": "number", "description": "Duration of the meeting in seconds." },
        "transcript": { "type": "string", "description": "Full transcript of the meeting." },
        "summary": { "type": "string", "description": "AI-generated summary of the meeting." },
        "actionItems": { "type": "array", "items": { "type": "string" }, "description": "List of action items extracted from the meeting." },
        "status": { "type": "string", "enum": ["recording", "processing", "completed", "error"], "description": "Current status of the meeting processing." }
      },
      "required": ["id", "userId", "title", "date", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Meeting records."
    }
  }
}
